# Bugadi — environment variables (TEMPLATE).
# Copy to .env.local and fill values YOURSELF. Never commit .env.local.
# The agent refers to these by NAME only and never holds the values.

# ── Payments ──
# "mock"  = simulated payment flow, NO gateway account needed (current).
# "razorpay" = real test-mode gateway (later; needs the Razorpay keys below).
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_SECRET=change-me-any-random-string   # signs the simulated webhook

# ── Supabase (region: Mumbai / ap-south-1) — NEEDED NOW ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never in the client bundle

# ── Shiprocket — needed for the shipping step ──
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ── Resend (transactional email) — needed for order email ──
RESEND_API_KEY=

# ── Razorpay (TEST MODE) — LATER, optional until you switch PAYMENT_PROVIDER=razorpay ──
RAZORPAY_KEY_ID=                    # rzp_test_...
RAZORPAY_KEY_SECRET=                # server-only
RAZORPAY_WEBHOOK_SECRET=            # server-only
NEXT_PUBLIC_RAZORPAY_KEY_ID=        # test key id, safe for the client

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
